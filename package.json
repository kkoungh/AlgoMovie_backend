{
  "name": "algomovie-api",
  "version": "1.0.0",
  "description": "AlgoMovie - AI 기반 영화 추천 시스템 백엔드 API",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "sync-movies": "node src/scripts/syncMovies.js",
    "load:test:recommendations": "node scripts/loadTestRecommendations.js",
    "lint": "eslint .",
    "format:check": "prettier --check \"src/**/*.js\" \"tests/**/*.js\" \"scripts/**/*.js\" \"jest.config.js\" \"eslint.config.js\"",
    "test": "jest",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "helmet": "^7.0.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.0",
    "pg": "^8.11.0"
  },
  "devDependencies": {
    "eslint": "^10.4.1",
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "prettier": "^3.8.3",
    "supertest": "^6.3.4"
  }
}
